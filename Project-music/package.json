{
  "name": "syncjam",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@syncjam/web",
    "dev:realtime": "npm run dev --workspace=@syncjam/realtime",
    "dev": "npm-run-all -p dev:realtime dev:web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  }
}
